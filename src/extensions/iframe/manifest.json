{
  "name": "runEver Content Injector",
  "version": "0.0.1",
  "manifest_version": 3,

  "permissions": ["scripting"],
  "host_permissions": ["<all_urls>"],

  "web_accessible_resources": [{
    "resources": ["miniHtml.js"],
    "matches": ["<all_urls>"]
  }],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}